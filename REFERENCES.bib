% ── [1–4] Core logic injection papers ────────────────────────────────────────

@inproceedings{yoo2019control,
  author    = {Yoo, Hyunguk and Ahmed, Irfan},
  title     = {Control Logic Injection Attacks on Industrial Control Systems},
  booktitle = {Proceedings of the 34th IFIP TC-11 International Conference
               on ICT Systems Security and Privacy Protection (SEC 2019)},
  year      = {2019},
  pages     = {33--48},
  publisher = {Springer},
  doi       = {10.1007/978-3-030-22312-0_3},
  note      = {Directly demonstrates injection of malicious IEC 61131-3 ladder
               logic via OpenPLC web interface — the exact technique implemented
               in attacker/logic\_injection.py of this project}
}

@inproceedings{govil2017ladder,
  author    = {Govil, Naman and Agrawal, Anand and Tippenhauer, Nils Ole},
  title     = {On Ladder Logic Bombs in Industrial Control Systems},
  booktitle = {Workshop on Attacks and Defenses for Internet-of-Things (ADIoT),
               co-located with ESORICS 2017},
  year      = {2017},
  publisher = {Springer},
  note      = {Introduces the term "ladder logic bomb" and formalises the
               attack class. Defines stealthy vs. overt injection and describes
               detection evasion techniques including the historian blindspot
               (Malicious Rung 4 in this project)}
}

@inproceedings{senthivel2018denial,
  author    = {Senthivel, Saranyan and Ahmed, Shabbir and Yoo, Hyunguk and
               Ahmed, Irfan and Roussev, Vassil},
  title     = {Denial of Engineering Operations Attacks on Industrial Control Systems},
  booktitle = {Proceedings of the 8th ACM Conference on Data and
               Application Security and Privacy (CODASPY 2018)},
  year      = {2018},
  pages     = {319--329},
  publisher = {ACM},
  doi       = {10.1145/3176258.3176294},
  note      = {Introduces the Denial of Engineering Operations (DoEO) attack class:
               an attacker modifies the running PLC program but also prevents the
               engineer from uploading corrective logic. Relevant to Stage G of
               logic\_injection.py and the "no recovery" scenario in apt\_scenario.py}
}

@inproceedings{mclaughlin2014stealthy,
  author    = {McLaughlin, Stephen E.},
  title     = {On Dynamic Malware Payloads Aimed at Programmable Logic Controllers},
  booktitle = {Proceedings of the 6th USENIX Workshop on Hot Topics in
               Security (HotSec 2011)},
  year      = {2011},
  publisher = {USENIX Association},
  note      = {Describes stealthy PLC payload delivery that mimics benign ladder
               logic to evade signature-based detection. The "look identical to
               original" design of the malicious rungs in logic\_injection.py
               follows this evasion strategy}
}

